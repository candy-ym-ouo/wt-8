generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                                                   Int                        @id @default(autoincrement())
  username                                             String                     @unique
  email                                                String                     @unique
  password                                             String
  avatar                                               String?
  bio                                                  String?
  role                                                 String                     @default("USER")
  createdAt                                            DateTime                   @default(now())
  updatedAt                                            DateTime                   @updatedAt
  appeals                                              Appeal[]                   @relation("AppealAppellant")
  handledAppeals                                       Appeal[]                   @relation("AppealHandler")
  AssetDownload                                        AssetDownload[]
  AssetResource                                        AssetResource[]
  benefitCheckLogs                                     BenefitCheckLog[]
  BrandCoop_BrandCoop_creatorIdToUser                  BrandCoop[]                @relation("BrandCoop_creatorIdToUser")
  BrandCoop_BrandCoop_reviewerIdToUser                 BrandCoop[]                @relation("BrandCoop_reviewerIdToUser")
  BrandCoopMessage                                     BrandCoopMessage[]
  calendarReminders                                    CalendarReminder[]
  calendarSubscriptions                                CalendarSubscription[]
  createdCollaborations                                Collaboration[]
  reviewedCollaborations                               Collaboration[]            @relation("CollaborationReviewer")
  reviewedCollaborationApplications                    CollaborationApplication[] @relation("CollaborationApplicationReviewer")
  collaborationApplications                            CollaborationApplication[]
  collaborationNotes                                   CollaborationNote[]
  createdCollections                                   Collection[]
  createdCompetitions                                  Competition[]              @relation("CompetitionCreator")
  judgedCompetitions                                   Competition[]              @relation("CompetitionJudge")
  competitionEntries                                   CompetitionEntry[]
  competitionScores                                    CompetitionScore[]
  CopyrightLicense_CopyrightLicense_reviewerIdToUser   CopyrightLicense[]         @relation("CopyrightLicense_reviewerIdToUser")
  CopyrightLicense_CopyrightLicense_authorIdToUser     CopyrightLicense[]         @relation("CopyrightLicense_authorIdToUser")
  CopyrightLicense_CopyrightLicense_applicantIdToUser  CopyrightLicense[]         @relation("CopyrightLicense_applicantIdToUser")
  CopyrightLicenseLog                                  CopyrightLicenseLog[]
  calendarEvents                                       CreationCalendar[]
  CreatorWallet                                        CreatorWallet?
  createdCrowdfundings                                 Crowdfunding[]
  reviewedCrowdfundings                                Crowdfunding[]             @relation("CrowdfundingReviewer")
  CrowdfundingComment                                  CrowdfundingComment[]
  CrowdfundingCommentLike                              CrowdfundingCommentLike[]
  ZineComment                                          ZineComment[]
  ZineCommentLike                                      ZineCommentLike[]
  zineCommentReplies                                   ZineComment[]             @relation("ReplyToUser")
  crowdfundingOrders                                   CrowdfundingOrder[]
  earlyAccesses                                        EarlyAccess[]
  editorTemplates                                      EditorTemplate[]
  createdEvents                                        Event[]
  operatedEventCheckIns                                EventCheckIn[]             @relation("EventCheckInOperator")
  eventCheckIns                                        EventCheckIn[]
  reviewedEventRegistrations                           EventRegistration[]        @relation("EventRegistrationReviewer")
  eventRegistrations                                   EventRegistration[]
  exclusiveZines                                       ExclusiveZine[]
  createdInterviews                                    Interview[]
  reviewedInterviews                                   Interview[]                @relation("InterviewReviewer")
  interviewedAs                                        Interview[]                @relation("InterviewAuthor")
  interviewComments                                    InterviewComment[]
  interviewSchedules                                   InterviewSchedule[]
  messagesReceived                                     Message[]                  @relation("MessageReceiver")
  messages                                             Message[]                  @relation("UserMessages")
  createdPrintOrders                                   PrintOrder[]
  reviewedPrintOrders                                  PrintOrder[]               @relation("PrintOrderReviewer")
  quotedPrintOrders                                    PrintOrder[]               @relation("PrintOrderQuoter")
  proofreadingCreated                                  ProofreadingTask[]         @relation("ProofreadingCreator")
  proofreadingAssigned                                 ProofreadingTask[]         @relation("ProofreadingAssignee")
  readingCheckIns                                      ReadingCheckIn[]
  readingCheckInComments                               ReadingCheckInComment[]    @relation("ReadingCheckInCommentUser")
  readingCheckInLikes                                  ReadingCheckInLike[]       @relation("ReadingCheckInLikeUser")
  readingReviews                                       ReadingReview[]
  readingReviewComments                                ReadingReviewComment[]     @relation("ReadingReviewCommentUser")
  readingReviewLikes                                   ReadingReviewLike[]        @relation("ReadingReviewLikeUser")
  readingStreaks                                       ReadingStreak?
  targetReports                                        Report[]                   @relation("ReportTarget")
  reportedBy                                           Report[]                   @relation("ReportReporter")
  reports                                              Report[]                   @relation("UserReports")
  reportLogs                                           ReportLog[]
  RevenueRecord                                        RevenueRecord[]
  reviewPerformance                                    ReviewPerformance?
  submissions                                          Submission[]
  subscriptions                                        Subscription[]
  createdSwapListings                                  SwapListing[]
  reviewedSwapListings                                 SwapListing[]              @relation("SwapListingReviewer")
  respondedSwapMatches                                 SwapMatch[]                @relation("SwapResponder")
  initiatedSwapMatches                                 SwapMatch[]                @relation("SwapInitiator")
  sentSwapMessages                                     SwapMessage[]              @relation("SwapMessageSender")
  createdTopics                                        Topic[]
  createdSchedules                                     TopicSchedule[]
  reviewedTopicSubmissions                             TopicSubmission[]          @relation("TopicSubmissionReviewer")
  topicSubmissions                                     TopicSubmission[]
  benefits                                             UserBenefit[]
  growth                                               UserGrowth?
  memberships                                          UserMembership[]
  WithdrawalAuditLog                                   WithdrawalAuditLog[]
  WithdrawalRequest_WithdrawalRequest_reviewerIdToUser WithdrawalRequest[]        @relation("WithdrawalRequest_reviewerIdToUser")
  WithdrawalRequest_WithdrawalRequest_userIdToUser     WithdrawalRequest[]        @relation("WithdrawalRequest_userIdToUser")
  workflowRecords                                      WorkflowRecord[]
  zines                                                Zine[]
}

model ReadingBook {
  id          Int              @id @default(autoincrement())
  title       String
  author      String
  coverImage  String?
  isbn        String?
  publisher   String?
  publishDate DateTime?
  category    String           @default("OTHER")
  tags        String           @default("[]")
  description String?
  pageCount   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  checkIns    ReadingCheckIn[]
  reviews     ReadingReview[]

  @@index([title])
  @@index([category])
}

model ReadingCheckIn {
  id           Int                     @id @default(autoincrement())
  userId       Int
  bookId       Int?
  bookTitle    String
  bookAuthor   String?
  pagesRead    Int                     @default(0)
  minutesRead  Int                     @default(0)
  mood         String                  @default("HAPPY")
  note         String?
  checkInDate  DateTime                @default(now())
  isPublic     Boolean                 @default(true)
  likeCount    Int                     @default(0)
  commentCount Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  book         ReadingBook?            @relation(fields: [bookId], references: [id])
  user         User                    @relation(fields: [userId], references: [id])
  comments     ReadingCheckInComment[]
  likes        ReadingCheckInLike[]

  @@unique([userId, checkInDate])
  @@index([userId])
  @@index([checkInDate])
  @@index([isPublic])
}

model ReadingCheckInLike {
  id        Int            @id @default(autoincrement())
  checkInId Int
  userId    Int
  createdAt DateTime       @default(now())
  user      User           @relation("ReadingCheckInLikeUser", fields: [userId], references: [id])
  checkIn   ReadingCheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@unique([checkInId, userId])
  @@index([userId])
}

model ReadingCheckInComment {
  id        Int            @id @default(autoincrement())
  checkInId Int
  userId    Int
  content   String
  status    String         @default("APPROVED")
  isPinned  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation("ReadingCheckInCommentUser", fields: [userId], references: [id])
  checkIn   ReadingCheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@index([checkInId])
  @@index([status])
}

model ReadingReview {
  id              Int                    @id @default(autoincrement())
  userId          Int
  bookId          Int?
  bookTitle       String
  bookAuthor      String?
  coverImage      String?
  title           String
  content         String
  rating          Int                    @default(5)
  category        String                 @default("OTHER")
  tags            String                 @default("[]")
  status          String                 @default("PUBLISHED")
  rejectionReason String?
  reviewerId      Int?
  reviewedAt      DateTime?
  isFeatured      Boolean                @default(false)
  sortOrder       Int                    @default(0)
  viewCount       Int                    @default(0)
  likeCount       Int                    @default(0)
  commentCount    Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  featured        FeaturedReadingReview?
  book            ReadingBook?           @relation(fields: [bookId], references: [id])
  user            User                   @relation(fields: [userId], references: [id])
  comments        ReadingReviewComment[]
  likes           ReadingReviewLike[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ReadingReviewLike {
  id        Int           @id @default(autoincrement())
  reviewId  Int
  userId    Int
  createdAt DateTime      @default(now())
  user      User          @relation("ReadingReviewLikeUser", fields: [userId], references: [id])
  review    ReadingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([userId])
}

model ReadingReviewComment {
  id        Int           @id @default(autoincrement())
  reviewId  Int
  userId    Int
  content   String
  status    String        @default("APPROVED")
  isPinned  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation("ReadingReviewCommentUser", fields: [userId], references: [id])
  review    ReadingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([status])
}

model ReadingStreak {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  totalCheckIns   Int       @default(0)
  totalMinutes    Int       @default(0)
  totalPages      Int       @default(0)
  lastCheckInDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeaturedReadingReview {
  id             Int           @id @default(autoincrement())
  reviewId       Int           @unique
  bannerImage    String?
  bannerTitle    String?
  bannerSubtitle String?
  sortOrder      Int           @default(0)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  review         ReadingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Collaboration {
  id              Int                        @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  category        String                     @default("OTHER")
  tags            String                     @default("[]")
  requirements    String?
  deliverables    String?
  compensation    String?
  deadline        DateTime?
  status          String                     @default("DRAFT")
  rejectionReason String?
  reviewerId      Int?
  reviewedAt      DateTime?
  isFeatured      Boolean                    @default(false)
  sortOrder       Int                        @default(0)
  viewCount       Int                        @default(0)
  creatorId       Int
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  creator         User                       @relation(fields: [creatorId], references: [id])
  reviewer        User?                      @relation("CollaborationReviewer", fields: [reviewerId], references: [id])
  applications    CollaborationApplication[]
}

model CollaborationApplication {
  id              Int           @id @default(autoincrement())
  collaborationId Int
  userId          Int
  portfolio       String?
  skills          String?
  motivation      String?
  contactInfo     String?
  status          String        @default("PENDING")
  rejectionReason String?
  reviewerId      Int?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reviewer        User?         @relation("CollaborationApplicationReviewer", fields: [reviewerId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)

  @@unique([collaborationId, userId])
}

model Zine {
  id                 Int                @id @default(autoincrement())
  title              String
  description        String
  coverImage         String
  content            String
  authorId           Int
  category           String
  tags               String
  status             String             @default("PUBLISHED")
  views              Int                @default(0)
  likes              Int                @default(0)
  commentCount       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  BrandCoopZine      BrandCoopZine[]
  collections        CollectionZine[]
  earlyAccesses      EarlyAccess[]
  interviewZines     InterviewZine[]
  proofreadingTasks  ProofreadingTask[]
  reviews            Review[]
  subscriptions      Subscription[]
  swapListingsAsWant SwapListing[]      @relation("WantZine")
  swapListingsAsHave SwapListing[]      @relation("HaveZine")
  author             User               @relation(fields: [authorId], references: [id])
  comments           ZineComment[]
}

model ZineComment {
  id              Int              @id @default(autoincrement())
  zineId          Int
  userId          Int
  content         String
  parentId        Int?
  replyToUserId   Int?
  likeCount       Int              @default(0)
  isPinned        Boolean          @default(false)
  status          String           @default("APPROVED")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  parent          ZineComment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies         ZineComment[]   @relation("CommentReplies")
  user            User             @relation(fields: [userId], references: [id])
  replyToUser     User?            @relation("ReplyToUser", fields: [replyToUserId], references: [id])
  zine            Zine             @relation(fields: [zineId], references: [id], onDelete: Cascade)
  likes           ZineCommentLike[]

  @@index([zineId])
  @@index([userId])
  @@index([parentId])
  @@index([status])
  @@index([createdAt])
}

model ZineCommentLike {
  id        Int         @id @default(autoincrement())
  commentId Int
  userId    Int
  createdAt DateTime    @default(now())
  comment   ZineComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model Submission {
  id                Int                @id @default(autoincrement())
  userId            Int
  title             String
  content           String
  images            String
  status            String             @default("DRAFT")
  rejectionReason   String?
  reviewerId        Int?
  reviewedAt        DateTime?
  scheduledAt       DateTime?
  withdrawnAt       DateTime?
  lastSavedAt       DateTime?
  version           Int                @default(1)
  autoSaveEnabled   Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  proofreadingTasks ProofreadingTask[]
  review            Review?
  user              User               @relation(fields: [userId], references: [id])

  @@index([scheduledAt])
  @@index([status])
  @@index([userId, status])
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  zineId    Int
  createdAt DateTime @default(now())
  zine      Zine     @relation(fields: [zineId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, zineId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  title      String
  content    String
  isRead     Boolean  @default(false)
  type       String   @default("SYSTEM")
  createdAt  DateTime @default(now())
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  sender     User     @relation("UserMessages", fields: [senderId], references: [id])
}

model Review {
  id           Int        @id @default(autoincrement())
  submissionId Int        @unique
  zineId       Int?
  status       String
  feedback     String?
  createdAt    DateTime   @default(now())
  zine         Zine?      @relation(fields: [zineId], references: [id])
  submission   Submission @relation(fields: [submissionId], references: [id])
}

model Topic {
  id             Int               @id @default(autoincrement())
  title          String
  description    String
  coverImage     String?
  content        String
  category       String
  tags           String            @default("[]")
  deadline       DateTime?
  startDate      DateTime?
  endDate        DateTime?
  status         String            @default("DRAFT")
  isFeatured     Boolean           @default(false)
  sortOrder      Int               @default(0)
  maxSubmissions Int               @default(0)
  requirements   String?
  prizes         String?
  creatorId      Int
  reviewers      String            @default("[]")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  featured       FeaturedTopic?
  creator        User              @relation(fields: [creatorId], references: [id])
  schedules      TopicSchedule[]
  submissions    TopicSubmission[]
}

model TopicSubmission {
  id              Int            @id @default(autoincrement())
  topicId         Int
  userId          Int
  title           String
  content         String
  images          String         @default("[]")
  status          String         @default("PENDING")
  rejectionReason String?
  reviewerId      Int?
  reviewedAt      DateTime?
  scheduleId      Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  schedule        TopicSchedule? @relation(fields: [scheduleId], references: [id])
  reviewer        User?          @relation("TopicSubmissionReviewer", fields: [reviewerId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  topic           Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model TopicSchedule {
  id          Int               @id @default(autoincrement())
  topicId     Int
  title       String
  description String?
  publishDate DateTime
  status      String            @default("PENDING")
  creatorId   Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  creator     User              @relation(fields: [creatorId], references: [id])
  topic       Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  submissions TopicSubmission[]
}

model FeaturedTopic {
  id             Int       @id @default(autoincrement())
  topicId        Int       @unique
  bannerImage    String?
  bannerTitle    String?
  bannerSubtitle String?
  sortOrder      Int       @default(0)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  topic          Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Level {
  id          Int          @id @default(autoincrement())
  name        String
  level       Int          @unique
  minExp      Int          @unique
  icon        String?
  description String?
  benefits    String       @default("[]")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userGrowths UserGrowth[]
}

model Badge {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  code         String        @unique
  icon         String
  description  String
  category     String        @default("GENERAL")
  rarity       String        @default("COMMON")
  expReward    Int           @default(0)
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  achievements Achievement[]
  userBadges   UserBadge[]
}

model Achievement {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  code             String            @unique
  description      String
  category         String            @default("CREATION")
  condition        String
  targetValue      Int               @default(1)
  expReward        Int               @default(0)
  badgeId          Int?
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  badge            Badge?            @relation(fields: [badgeId], references: [id])
  userAchievements UserAchievement[]
}

model Task {
  id          Int        @id @default(autoincrement())
  name        String
  code        String     @unique
  description String
  category    String     @default("DAILY")
  type        String     @default("SUBMISSION")
  condition   String
  targetValue Int        @default(1)
  expReward   Int        @default(10)
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userTasks   UserTask[]
}

model Benefit {
  id           Int           @id @default(autoincrement())
  name         String
  code         String        @unique
  description  String
  type         String        @default("PRIVILEGE")
  value        String?
  minLevel     Int           @default(1)
  sortOrder    Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userBenefits UserBenefit[]
}

model UserGrowth {
  id               Int               @id @default(autoincrement())
  userId           Int               @unique
  totalExp         Int               @default(0)
  currentExp       Int               @default(0)
  levelId          Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  growthLogs       GrowthLog[]
  userAchievements UserAchievement[]
  userBadges       UserBadge[]
  level            Level?            @relation(fields: [levelId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  userTasks        UserTask[]
}

model UserBadge {
  id           Int        @id @default(autoincrement())
  userGrowthId Int
  badgeId      Int
  unlockedAt   DateTime   @default(now())
  source       String?
  badge        Badge      @relation(fields: [badgeId], references: [id])
  userGrowth   UserGrowth @relation(fields: [userGrowthId], references: [id])

  @@unique([userGrowthId, badgeId])
}

model UserAchievement {
  id            Int         @id @default(autoincrement())
  userGrowthId  Int
  achievementId Int
  progress      Int         @default(0)
  isCompleted   Boolean     @default(false)
  completedAt   DateTime?
  claimedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  userGrowth    UserGrowth  @relation(fields: [userGrowthId], references: [id])

  @@unique([userGrowthId, achievementId])
}

model UserTask {
  id           Int        @id @default(autoincrement())
  userGrowthId Int
  taskId       Int
  progress     Int        @default(0)
  isCompleted  Boolean    @default(false)
  completedAt  DateTime?
  claimedAt    DateTime?
  date         String
  week         String?
  month        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  task         Task       @relation(fields: [taskId], references: [id])
  userGrowth   UserGrowth @relation(fields: [userGrowthId], references: [id])

  @@unique([userGrowthId, taskId, date])
}

model GrowthLog {
  id           Int        @id @default(autoincrement())
  userGrowthId Int
  type         String
  amount       Int        @default(0)
  description  String
  sourceType   String?
  sourceId     Int?
  createdAt    DateTime   @default(now())
  userGrowth   UserGrowth @relation(fields: [userGrowthId], references: [id])
}

model UserBenefit {
  id          Int       @id @default(autoincrement())
  userId      Int
  benefitId   Int
  isActive    Boolean   @default(true)
  activatedAt DateTime  @default(now())
  expiresAt   DateTime?
  benefit     Benefit   @relation(fields: [benefitId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, benefitId])
}

model Event {
  id                   Int                 @id @default(autoincrement())
  title                String
  description          String
  coverImage           String?
  location             String
  address              String?
  category             String              @default("OTHER")
  tags                 String              @default("[]")
  startTime            DateTime
  endTime              DateTime
  registrationDeadline DateTime?
  maxParticipants      Int                 @default(0)
  minParticipants      Int                 @default(0)
  fee                  Float               @default(0)
  organizer            String?
  organizerContact     String?
  requirements         String?
  notice               String?
  status               String              @default("DRAFT")
  isFeatured           Boolean             @default(false)
  sortOrder            Int                 @default(0)
  viewCount            Int                 @default(0)
  creatorId            Int
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  creator              User                @relation(fields: [creatorId], references: [id])
  checkIns             EventCheckIn[]
  registrations        EventRegistration[]
}

model EventRegistration {
  id              Int           @id @default(autoincrement())
  eventId         Int
  userId          Int
  name            String
  phone           String
  email           String?
  company         String?
  note            String?
  status          String        @default("PENDING")
  rejectionReason String?
  reviewerId      Int?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  checkIn         EventCheckIn?
