  sortOrder       Int                @default(0)
  viewCount       Int                @default(0)
  entryCount      Int                @default(0)
  scoringMode     String             @default("AVERAGE")
  isResultPublic  Boolean            @default(false)
  creatorId       Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  creator         User               @relation("CompetitionCreator", fields: [creatorId], references: [id])
  reviewer        User?              @relation("CompetitionJudge", fields: [reviewerId], references: [id])
  entries         CompetitionEntry[]
  groups          CompetitionGroup[]

  @@index([status])
  @@index([creatorId])
  @@index([category])
  @@index([startDate])
  @@index([createdAt])
}

model CompetitionGroup {
  id            Int                @id @default(autoincrement())
  competitionId Int
  name          String
  description   String?
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  entries       CompetitionEntry[]
  competition   Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
}

model CompetitionEntry {
  id              Int                @id @default(autoincrement())
  competitionId   Int
  groupId         Int?
  userId          Int
  title           String
  content         String
  images          String             @default("[]")
  status          String             @default("PENDING")
  rejectionReason String?
  reviewerId      Int?
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id])
  group           CompetitionGroup?  @relation(fields: [groupId], references: [id])
  competition     Competition        @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  scores          CompetitionScore[]

  @@unique([competitionId, userId])
  @@index([competitionId])
  @@index([groupId])
  @@index([userId])
  @@index([status])
}

model CompetitionScore {
  id        Int              @id @default(autoincrement())
  entryId   Int
  judgeId   Int
  score     Float            @default(0)
  comment   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  judge     User             @relation(fields: [judgeId], references: [id])
  entry     CompetitionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, judgeId])
  @@index([entryId])
  @@index([judgeId])
}

model AssetCategory {
  id            Int             @id @default(autoincrement())
  name          String
  slug          String          @unique
  icon          String?
  description   String?
  type          String          @default("GENERAL")
  sortOrder     Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  AssetResource AssetResource[]

  @@index([sortOrder])
  @@index([type])
}

model AssetDownload {
  id            Int           @id @default(autoincrement())
  resourceId    Int
  userId        Int
  status        String        @default("SUCCESS")
  failReason    String?
  createdAt     DateTime      @default(now())
  User          User          @relation(fields: [userId], references: [id])
  AssetResource AssetResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, userId])
  @@index([createdAt])
  @@index([userId])
}

model AssetResource {
  id            Int             @id @default(autoincrement())
  title         String
  description   String?
  coverImage    String?
  fileUrl       String
  fileName      String          @default("")
  fileSize      Int             @default(0)
  fileType      String          @default("IMAGE")
  categoryId    Int
  tags          String          @default("[]")
  type          String          @default("COVER_TEMPLATE")
  minLevel      Int             @default(0)
  requirePlan   Boolean         @default(false)
  isFree        Boolean         @default(true)
  status        String          @default("PUBLISHED")
  viewCount     Int             @default(0)
  downloadCount Int             @default(0)
  isFeatured    Boolean         @default(false)
  sortOrder     Int             @default(0)
  creatorId     Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  AssetDownload AssetDownload[]
  User          User            @relation(fields: [creatorId], references: [id])
  AssetCategory AssetCategory   @relation(fields: [categoryId], references: [id])

  @@index([createdAt])
  @@index([sortOrder])
  @@index([isFeatured])
  @@index([status])
  @@index([type])
  @@index([categoryId])
}

model BrandCoop {
  id                              Int                 @id @default(autoincrement())
  title                           String
  brandName                       String
  brandLogo                       String?
  description                     String
  coverImage                      String?
  category                        String              @default("COBRANDING")
  tags                            String              @default("[]")
  cooperationType                 String              @default("COBRANDING")
  contactPerson                   String?
  contactPhone                    String?
  contactEmail                    String?
  budget                          String?
  startDate                       DateTime?
  endDate                         DateTime?
  requirements                    String?
  deliverables                    String?
  notes                           String?
  status                          String              @default("DRAFT")
  kanbanColumn                    String              @default("PROPOSAL")
  sortOrder                       Int                 @default(0)
  rejectionReason                 String?
  reviewerId                      Int?
  reviewedAt                      DateTime?
  isFeatured                      Boolean             @default(false)
  viewCount                       Int                 @default(0)
  creatorId                       Int
  createdAt                       DateTime            @default(now())
  updatedAt                       DateTime
  User_BrandCoop_creatorIdToUser  User                @relation("BrandCoop_creatorIdToUser", fields: [creatorId], references: [id])
  User_BrandCoop_reviewerIdToUser User?               @relation("BrandCoop_reviewerIdToUser", fields: [reviewerId], references: [id])
  BrandCoopMessage                BrandCoopMessage[]
  BrandCoopSchedule               BrandCoopSchedule[]
  BrandCoopZine                   BrandCoopZine[]

  @@index([createdAt])
  @@index([category])
  @@index([creatorId])
  @@index([kanbanColumn])
  @@index([status])
}

model BrandCoopMessage {
  id          Int       @id @default(autoincrement())
  brandCoopId Int
  senderId    Int
  content     String
  type        String    @default("TEXT")
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  User        User      @relation(fields: [senderId], references: [id])
  BrandCoop   BrandCoop @relation(fields: [brandCoopId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([senderId])
  @@index([brandCoopId])
}

model BrandCoopSchedule {
  id          Int       @id @default(autoincrement())
  brandCoopId Int
  title       String
  description String?
  plannedDate DateTime
  actualDate  DateTime?
  status      String    @default("PENDING")
  assigneeId  Int?
  remark      String?
  sortOrder   Int       @default(0)
  creatorId   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  BrandCoop   BrandCoop @relation(fields: [brandCoopId], references: [id], onDelete: Cascade)

  @@index([plannedDate])
  @@index([status])
  @@index([brandCoopId])
}

model BrandCoopZine {
  id            Int       @id @default(autoincrement())
  brandCoopId   Int
  zineId        Int
  role          String    @default("RELATED")
  recommendNote String?
  sortOrder     Int       @default(0)
  addedAt       DateTime  @default(now())
  Zine          Zine      @relation(fields: [zineId], references: [id], onDelete: Cascade)
  BrandCoop     BrandCoop @relation(fields: [brandCoopId], references: [id], onDelete: Cascade)

  @@unique([brandCoopId, zineId])
  @@index([zineId])
  @@index([brandCoopId])
}

model CopyrightLicense {
  id                                      Int                   @id @default(autoincrement())
  licenseNo                               String                @unique
  title                                   String
  workId                                  Int
  workType                                String
  workTitle                               String
  workCoverImage                          String?
  purposeCategory                         String                @default("OTHER")
  purposeDetail                           String
  usageScope                              String                @default("PERSONAL")
  useRegions                              String                @default("[]")
  commercialUse                           Boolean               @default(false)
  derivativeAllowed                       Boolean               @default(false)
  distributeAllowed                       Boolean               @default(false)
  attributionRequired                     Boolean               @default(true)
  licenseType                             String                @default("STANDARD")
  licenseFee                              Float                 @default(0)
  paymentStatus                           String                @default("UNPAID")
  startDate                               DateTime?
  endDate                                 DateTime?
  durationDays                            Int                   @default(0)
  applicantId                             Int
  applicantContact                        String?
  applicantCompany                        String?
  authorId                                Int
  authorConfirmed                         Boolean               @default(false)
  authorConfirmedAt                       DateTime?
  authorConfirmRemark                     String?
  authorAskedPrice                        Float?
  authorContractTerms                     String?
  status                                  String                @default("DRAFT")
  rejectionReason                         String?
  reviewerId                              Int?
  reviewedAt                              DateTime?
  reviewRemark                            String?
  contractContent                         String?
  contractFile                            String?
  contractSigned                          Boolean               @default(false)
  contractSignedAt                        DateTime?
  attachments                             String                @default("[]")
  viewedCount                             Int                   @default(0)
  createdAt                               DateTime              @default(now())
  updatedAt                               DateTime
  User_CopyrightLicense_reviewerIdToUser  User?                 @relation("CopyrightLicense_reviewerIdToUser", fields: [reviewerId], references: [id])
  User_CopyrightLicense_authorIdToUser    User                  @relation("CopyrightLicense_authorIdToUser", fields: [authorId], references: [id])
  User_CopyrightLicense_applicantIdToUser User                  @relation("CopyrightLicense_applicantIdToUser", fields: [applicantId], references: [id])
  CopyrightLicenseLog                     CopyrightLicenseLog[]

  @@index([licenseType])
  @@index([createdAt])
  @@index([workType, workId])
  @@index([status])
  @@index([authorId])
  @@index([applicantId])
}

model CopyrightLicenseLog {
  id               Int              @id @default(autoincrement())
  licenseId        Int
  action           String
  fromStatus       String?
  toStatus         String?
  detail           String?
  metadata         String           @default("{}")
  operatorId       Int
  createdAt        DateTime         @default(now())
  User             User             @relation(fields: [operatorId], references: [id])
  CopyrightLicense CopyrightLicense @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([action])
  @@index([operatorId])
  @@index([licenseId])
}

model CreatorWallet {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  balance         Float    @default(0)
  frozenAmount    Float    @default(0)
  totalRevenue    Float    @default(0)
  totalWithdrawn  Float    @default(0)
  pendingWithdraw Float    @default(0)
  bankName        String?
  bankAccount     String?
  bankAccountName String?
  alipayAccount   String?
  wechatAccount   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  User            User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CrowdfundingComment {
  id                        Int                       @id @default(autoincrement())
  crowdfundingId            Int
  userId                    Int
  content                   String
  parentId                  Int?
  replyToUserId             Int?
  likeCount                 Int                       @default(0)
  isPinned                  Boolean                   @default(false)
  status                    String                    @default("APPROVED")
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime
  CrowdfundingComment       CrowdfundingComment?      @relation("CrowdfundingCommentToCrowdfundingComment", fields: [parentId], references: [id], onDelete: Cascade)
  other_CrowdfundingComment CrowdfundingComment[]     @relation("CrowdfundingCommentToCrowdfundingComment")
  User                      User                      @relation(fields: [userId], references: [id])
  Crowdfunding              Crowdfunding              @relation(fields: [crowdfundingId], references: [id], onDelete: Cascade)
  CrowdfundingCommentLike   CrowdfundingCommentLike[]

  @@index([createdAt])
  @@index([status])
  @@index([parentId])
  @@index([userId])
  @@index([crowdfundingId])
}

model CrowdfundingCommentLike {
  id                  Int                 @id @default(autoincrement())
  commentId           Int
  userId              Int
  createdAt           DateTime            @default(now())
  User                User                @relation(fields: [userId], references: [id])
  CrowdfundingComment CrowdfundingComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@index([commentId])
}

model RevenueRecord {
  id          Int          @id @default(autoincrement())
  userId      Int
  type        String
  sourceType  String
  sourceId    Int?
  sourceTitle String?
  amount      Float
  description String?
  status      String       @default("SETTLED")
  ruleId      Int?
  orderNo     String?
  settleDate  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  RevenueRule RevenueRule? @relation(fields: [ruleId], references: [id])
  User        User         @relation(fields: [userId], references: [id])

  @@index([settleDate])
  @@index([createdAt])
  @@index([status])
  @@index([sourceType, sourceId])
  @@index([type])
  @@index([userId])
}

model RevenueRule {
  id            Int             @id @default(autoincrement())
  name          String
  code          String          @unique
  description   String?
  type          String
  rate          Float           @default(0)
  baseAmount    Float           @default(0)
  minAmount     Float           @default(0)
  maxAmount     Float?
  level         Int             @default(1)
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  RevenueRecord RevenueRecord[]

  @@index([sortOrder])
  @@index([isActive])
  @@index([type])
}

model WithdrawalAuditLog {
  id                Int               @id @default(autoincrement())
  withdrawalId      Int
  action            String
  fromStatus        String?
  toStatus          String?
  remark            String?
  operatorId        Int
  createdAt         DateTime          @default(now())
  User              User              @relation(fields: [operatorId], references: [id])
  WithdrawalRequest WithdrawalRequest @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([action])
  @@index([operatorId])
  @@index([withdrawalId])
}

model WithdrawalRequest {
  id                                      Int                  @id @default(autoincrement())
  withdrawNo                              String               @unique
  userId                                  Int
  amount                                  Float
  fee                                     Float                @default(0)
  actualAmount                            Float
  withdrawMethod                          String
  bankName                                String?
  bankAccount                             String?
  bankAccountName                         String?
  alipayAccount                           String?
  wechatAccount                           String?
  status                                  String               @default("PENDING")
  rejectionReason                         String?
  reviewerId                              Int?
  reviewedAt                              DateTime?
  paidAt                                  DateTime?
  transactionNo                           String?
  remark                                  String?
  createdAt                               DateTime             @default(now())
  updatedAt                               DateTime
  WithdrawalAuditLog                      WithdrawalAuditLog[]
  User_WithdrawalRequest_reviewerIdToUser User?                @relation("WithdrawalRequest_reviewerIdToUser", fields: [reviewerId], references: [id])
  User_WithdrawalRequest_userIdToUser     User                 @relation("WithdrawalRequest_userIdToUser", fields: [userId], references: [id])

  @@index([reviewedAt])
  @@index([createdAt])
  @@index([status])
  @@index([userId])
}
