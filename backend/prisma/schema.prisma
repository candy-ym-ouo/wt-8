  rejectionReason      String?

  reviewerId           Int?
  reviewer             User?                @relation("LicenseReviewer", fields: [reviewerId], references: [id])
  reviewedAt           DateTime?
  reviewRemark         String?

  contractContent      String?
  contractFile         String?
  contractSigned       Boolean              @default(false)
  contractSignedAt     DateTime?
  attachments          String               @default("[]")

  viewedCount          Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  logs                 CopyrightLicenseLog[]

  @@index([applicantId])
  @@index([authorId])
  @@index([status])
  @@index([workType, workId])
  @@index([createdAt])
  @@index([licenseType])
}

model CopyrightLicenseLog {
  id          Int               @id @default(autoincrement())
  licenseId   Int
  license     CopyrightLicense  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  action      String
  fromStatus  String?
  toStatus    String?
  detail      String?
  metadata    String            @default("{}")
  operatorId  Int
  operator    User              @relation("LicenseLogOperator", fields: [operatorId], references: [id])
  createdAt   DateTime          @default(now())

  @@index([licenseId])
  @@index([operatorId])
  @@index([action])
  @@index([createdAt])
}
