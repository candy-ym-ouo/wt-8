generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zines       Zine[]
  submissions Submission[]
  messages    Message[]    @relation("UserMessages")
  messagesReceived Message[] @relation("MessageReceiver")
  subscriptions Subscription[]
  createdTopics Topic[]
  topicSubmissions TopicSubmission[]
  reviewedTopicSubmissions TopicSubmission[] @relation("TopicSubmissionReviewer")
  createdSchedules TopicSchedule[]
  growth      UserGrowth?
  benefits    UserBenefit[]
  createdEvents Event[]
  eventRegistrations EventRegistration[]
  reviewedEventRegistrations EventRegistration[] @relation("EventRegistrationReviewer")
  eventCheckIns EventCheckIn[]
  operatedEventCheckIns EventCheckIn[] @relation("EventCheckInOperator")
  createdCollections Collection[]
  createdCollaborations Collaboration[]
  reviewedCollaborations Collaboration[] @relation("CollaborationReviewer")
  collaborationApplications CollaborationApplication[]
  reviewedCollaborationApplications CollaborationApplication[] @relation("CollaborationApplicationReviewer")
  createdCrowdfundings Crowdfunding[]
  reviewedCrowdfundings Crowdfunding[] @relation("CrowdfundingReviewer")
  crowdfundingOrders CrowdfundingOrder[]
  reports Report[] @relation("UserReports")
  reportedBy Report[] @relation("ReportReporter")
  targetReports Report[] @relation("ReportTarget")
  appeals Appeal[] @relation("AppealAppellant")
  handledAppeals Appeal[] @relation("AppealHandler")
  reportLogs ReportLog[]
  calendarEvents CreationCalendar[]
  calendarReminders CalendarReminder[]
  calendarSubscriptions CalendarSubscription[]
  proofreadingAssigned ProofreadingTask[] @relation("ProofreadingAssignee")
  proofreadingCreated ProofreadingTask[] @relation("ProofreadingCreator")
  editorTemplates EditorTemplate[]
  collaborationNotes CollaborationNote[]
  workflowRecords WorkflowRecord[]
  reviewPerformance ReviewPerformance?
  createdSwapListings SwapListing[]
  reviewedSwapListings SwapListing[] @relation("SwapListingReviewer")
  initiatedSwapMatches SwapMatch[] @relation("SwapInitiator")
  respondedSwapMatches SwapMatch[] @relation("SwapResponder")
  sentSwapMessages SwapMessage[] @relation("SwapMessageSender")
  memberships     UserMembership[]
  benefitCheckLogs BenefitCheckLog[]
  exclusiveZines  ExclusiveZine[]
  earlyAccesses   EarlyAccess[]
  createdInterviews Interview[]
  reviewedInterviews Interview[] @relation("InterviewReviewer")
  interviewComments InterviewComment[]
  interviewSchedules InterviewSchedule[]
  interviewedAs   Interview[] @relation("InterviewAuthor")
  createdPrintOrders PrintOrder[]
  reviewedPrintOrders PrintOrder[] @relation("PrintOrderReviewer")
  quotedPrintOrders  PrintOrder[] @relation("PrintOrderQuoter")

  readingCheckIns ReadingCheckIn[]
  readingReviews ReadingReview[]
  readingReviewLikes ReadingReviewLike[] @relation("ReadingReviewLikeUser")
  readingReviewComments ReadingReviewComment[] @relation("ReadingReviewCommentUser")
  readingCheckInLikes ReadingCheckInLike[] @relation("ReadingCheckInLikeUser")
  readingCheckInComments ReadingCheckInComment[] @relation("ReadingCheckInCommentUser")
  readingStreaks ReadingStreak[]

  createdCompetitions Competition[] @relation("CompetitionCreator")
  competitionEntries CompetitionEntry[]
  judgedCompetitions Competition[] @relation("CompetitionJudge")
  competitionScores CompetitionScore[]

  licenseApplications CopyrightLicense[] @relation("LicenseApplicant")
  authoredLicenses CopyrightLicense[] @relation("LicenseAuthor")
  reviewedLicenses CopyrightLicense[] @relation("LicenseReviewer")
  licenseOperationLogs CopyrightLicenseLog[] @relation("LicenseLogOperator")
}

model ReadingBook {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  coverImage  String?
  isbn        String?
  publisher   String?
  publishDate DateTime?
  category    String   @default("OTHER")
  tags        String   @default("[]")
  description String?
  pageCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checkIns    ReadingCheckIn[]
  reviews     ReadingReview[]

  @@index([title])
  @@index([category])
}

model ReadingCheckIn {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id])
  bookId        Int?
  book          ReadingBook? @relation(fields: [bookId], references: [id])
  bookTitle     String
  bookAuthor    String?
  pagesRead     Int       @default(0)
  minutesRead   Int       @default(0)
  mood          String    @default("HAPPY")
  note          String?
  checkInDate   DateTime  @default(now())
  isPublic      Boolean   @default(true)
  likeCount     Int       @default(0)
  commentCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  likes         ReadingCheckInLike[]
  comments      ReadingCheckInComment[]

  @@unique([userId, checkInDate])
  @@index([userId])
  @@index([checkInDate])
  @@index([isPublic])
}

model ReadingCheckInLike {
  id          Int       @id @default(autoincrement())
  checkInId   Int
  checkIn     ReadingCheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  userId      Int
  user        User @relation("ReadingCheckInLikeUser", fields: [userId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([checkInId, userId])
  @@index([userId])
}

model ReadingCheckInComment {
  id          Int       @id @default(autoincrement())
  checkInId   Int
  checkIn     ReadingCheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  userId      Int
  user        User      @relation("ReadingCheckInCommentUser", fields: [userId], references: [id])
  content     String
  status      String    @default("APPROVED")
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([checkInId])
  @@index([status])
}

model ReadingReview {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id])
  bookId        Int?
  book          ReadingBook? @relation(fields: [bookId], references: [id])
  bookTitle     String
  bookAuthor    String?
  coverImage    String?
  title         String
  content       String
  rating        Int       @default(5)
  category      String    @default("OTHER")
  tags          String    @default("[]")
  status        String    @default("PUBLISHED")
  rejectionReason String?
  reviewerId    Int?
  reviewedAt    DateTime?
  isFeatured    Boolean   @default(false)
  sortOrder     Int       @default(0)
  viewCount     Int       @default(0)
  likeCount     Int       @default(0)
  commentCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  likes         ReadingReviewLike[]
  comments      ReadingReviewComment[]
  featured      FeaturedReadingReview?

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ReadingReviewLike {
  id          Int       @id @default(autoincrement())
  reviewId    Int
  review      ReadingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId      Int
  user        User @relation("ReadingReviewLikeUser", fields: [userId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([reviewId, userId])
  @@index([userId])
}

model ReadingReviewComment {
  id          Int       @id @default(autoincrement())
  reviewId    Int
  review      ReadingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId      Int
  user        User      @relation("ReadingReviewCommentUser", fields: [userId], references: [id])
  content     String
  status      String    @default("APPROVED")
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([reviewId])
  @@index([status])
}

model ReadingStreak {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  totalCheckIns   Int      @default(0)
  totalMinutes    Int      @default(0)
  totalPages      Int      @default(0)
  lastCheckInDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FeaturedReadingReview {
  id              Int       @id @default(autoincrement())
  reviewId        Int       @unique
  review          ReadingReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  bannerImage     String?
  bannerTitle     String?
  bannerSubtitle  String?
  sortOrder       Int       @default(0)
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Collaboration {
  id              Int                         @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  category        String                      @default("OTHER")
  tags            String                      @default("[]")
  requirements    String?
  deliverables    String?
  compensation    String?
  deadline        DateTime?
  status          String                      @default("DRAFT")
  rejectionReason String?
  reviewerId      Int?
  reviewer        User?                       @relation("CollaborationReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  isFeatured      Boolean                     @default(false)
  sortOrder       Int                         @default(0)
  viewCount       Int                         @default(0)
  creatorId       Int
  creator         User                        @relation(fields: [creatorId], references: [id])
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  applications    CollaborationApplication[]
}

model CollaborationApplication {
  id              Int           @id @default(autoincrement())
  collaborationId Int
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  portfolio       String?
  skills          String?
  motivation      String?
  contactInfo     String?
  status          String        @default("PENDING")
  rejectionReason String?
  reviewerId      Int?
  reviewer        User?         @relation("CollaborationApplicationReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([collaborationId, userId])
}

model Zine {
  id          Int         @id @default(autoincrement())
  title       String
  description String
  coverImage  String
  content     String
  authorId    Int
  author      User        @relation(fields: [authorId], references: [id])
  category    String
  tags        String
  status      String      @default("PUBLISHED")
  views       Int         @default(0)
  likes       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subscriptions Subscription[]
  reviews       Review[]
  collections   CollectionZine[]
  proofreadingTasks ProofreadingTask[]
  swapListingsAsHave SwapListing[] @relation("HaveZine")
  swapListingsAsWant SwapListing[] @relation("WantZine")
  earlyAccesses EarlyAccess[]
  interviewZines InterviewZine[]
}

model Submission {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  content     String
  images      String
  status      String   @default("PENDING")
  rejectionReason String?
  reviewerId  Int?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  review Review?
  proofreadingTasks ProofreadingTask[]
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  zineId    Int
  zine      Zine     @relation(fields: [zineId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, zineId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("UserMessages", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  title      String
  content    String
  isRead     Boolean  @default(false)
  type       String   @default("SYSTEM")
  createdAt  DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  submissionId Int  @unique
  submission   Submission @relation(fields: [submissionId], references: [id])
  zineId    Int?
  zine      Zine?    @relation(fields: [zineId], references: [id])
  status    String
  feedback  String?
  createdAt DateTime @default(now())
}

model Topic {
  id              Int               @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  content         String
  category        String
  tags            String            @default("[]")
  deadline        DateTime?
  startDate       DateTime?
  endDate         DateTime?
  status          String            @default("DRAFT")
  isFeatured      Boolean           @default(false)
  sortOrder       Int               @default(0)
  maxSubmissions  Int               @default(0)
  requirements    String?
  prizes          String?
  creatorId       Int
  creator         User              @relation(fields: [creatorId], references: [id])
  reviewers       String            @default("[]")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  submissions     TopicSubmission[]
  schedules       TopicSchedule[]
  featured        FeaturedTopic?
}

model TopicSubmission {
  id          Int      @id @default(autoincrement())
  topicId     Int
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  content     String
  images      String   @default("[]")
  status      String   @default("PENDING")
  rejectionReason String?
  reviewerId  Int?
  reviewer    User?    @relation("TopicSubmissionReviewer", fields: [reviewerId], references: [id])
  reviewedAt  DateTime?
  scheduleId  Int?
  schedule    TopicSchedule? @relation(fields: [scheduleId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TopicSchedule {
  id            Int               @id @default(autoincrement())
  topicId       Int
  topic         Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  publishDate   DateTime
  status        String            @default("PENDING")
  creatorId     Int
  creator       User              @relation(fields: [creatorId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  submissions   TopicSubmission[]
}

model FeaturedTopic {
  id         Int      @id @default(autoincrement())
  topicId    Int      @unique
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  bannerImage String?
  bannerTitle String?
  bannerSubtitle String?
  sortOrder  Int      @default(0)
  startDate  DateTime?
  endDate    DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Level {
  id          Int          @id @default(autoincrement())
  name        String
  level       Int          @unique
  minExp      Int          @unique
  icon        String?
  description String?
  benefits    String       @default("[]")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userGrowths UserGrowth[]
}

model Badge {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  code          String         @unique
  icon          String
  description   String
  category      String         @default("GENERAL")
  rarity        String         @default("COMMON")
  expReward     Int            @default(0)
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  userBadges    UserBadge[]
  achievements  Achievement[]
}

model Achievement {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  description String
  category    String   @default("CREATION")
  condition   String
  targetValue Int      @default(1)
  expReward   Int      @default(0)
  badgeId     Int?
  badge       Badge?   @relation(fields: [badgeId], references: [id])
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userAchievements UserAchievement[]
}

model Task {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String
  category    String   @default("DAILY")
  type        String   @default("SUBMISSION")
  condition   String
  targetValue Int      @default(1)
  expReward   Int      @default(10)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userTasks   UserTask[]
}

model Benefit {
  id          Int           @id @default(autoincrement())
  name        String
  code        String        @unique
  description String
  type        String        @default("PRIVILEGE")
  value       String?
  minLevel    Int           @default(1)
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userBenefits UserBenefit[]
}

model UserGrowth {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  totalExp    Int      @default(0)
  currentExp  Int      @default(0)
  levelId     Int?
  level       Level?   @relation(fields: [levelId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBadges      UserBadge[]
  userAchievements UserAchievement[]
  userTasks       UserTask[]
  growthLogs      GrowthLog[]
}

model UserBadge {
  id          Int      @id @default(autoincrement())
  userGrowthId Int
  userGrowth  UserGrowth @relation(fields: [userGrowthId], references: [id])
  badgeId     Int
  badge       Badge    @relation(fields: [badgeId], references: [id])
  unlockedAt  DateTime @default(now())
  source      String?

  @@unique([userGrowthId, badgeId])
}

model UserAchievement {
  id          Int      @id @default(autoincrement())
  userGrowthId Int
  userGrowth  UserGrowth @relation(fields: [userGrowthId], references: [id])
  achievementId Int
  achievement Achievement @relation(fields: [achievementId], references: [id])
  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userGrowthId, achievementId])
}

model UserTask {
  id          Int      @id @default(autoincrement())
  userGrowthId Int
  userGrowth  UserGrowth @relation(fields: [userGrowthId], references: [id])
  taskId      Int
  task        Task     @relation(fields: [taskId], references: [id])
  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  date        String
  week        String?
  month       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userGrowthId, taskId, date])
}

model GrowthLog {
  id          Int      @id @default(autoincrement())
  userGrowthId Int
  userGrowth  UserGrowth @relation(fields: [userGrowthId], references: [id])
  type        String
  amount      Int      @default(0)
  description String
  sourceType  String?
  sourceId    Int?
  createdAt   DateTime @default(now())
}

model UserBenefit {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  benefitId   Int
  benefit     Benefit  @relation(fields: [benefitId], references: [id])
  isActive    Boolean  @default(true)
  activatedAt DateTime @default(now())
  expiresAt   DateTime?

  @@unique([userId, benefitId])
}

model Event {
  id              Int                @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  location        String
  address         String?
  category        String             @default("OTHER")
  tags            String             @default("[]")
  startTime       DateTime
  endTime         DateTime
  registrationDeadline DateTime?
  maxParticipants Int                @default(0)
  minParticipants Int                @default(0)
  fee             Float              @default(0)
  organizer       String?
  organizerContact String?
  requirements    String?
  notice          String?
  status          String             @default("DRAFT")
  isFeatured      Boolean            @default(false)
  sortOrder       Int                @default(0)
  viewCount       Int                @default(0)
  creatorId       Int
  creator         User               @relation(fields: [creatorId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  registrations   EventRegistration[]
  checkIns        EventCheckIn[]
}

model EventRegistration {
  id          Int      @id @default(autoincrement())
  eventId     Int
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  name        String
  phone       String
  email       String?
  company     String?
  note        String?
  status      String   @default("PENDING")
  rejectionReason String?
  reviewerId  Int?
  reviewer    User?    @relation("EventRegistrationReviewer", fields: [reviewerId], references: [id])
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checkIn     EventCheckIn?

  @@unique([eventId, userId])
}

model EventCheckIn {
  id              Int      @id @default(autoincrement())
  eventId         Int
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationId  Int      @unique
  registration    EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  checkInTime     DateTime @default(now())
  checkInType     String   @default("QRCODE")
  operatorId      Int?
  operator        User?    @relation("EventCheckInOperator", fields: [operatorId], references: [id])
  remark          String?
  createdAt       DateTime @default(now())

  @@unique([eventId, registrationId])
}

model Collection {
  id          Int              @id @default(autoincrement())
  title       String
  description String
  coverImage  String?
  content     String
  category    String
  tags        String           @default("[]")
  status      String           @default("DRAFT")
  sortOrder   Int              @default(0)
  viewCount   Int              @default(0)
  likeCount   Int              @default(0)
  isFeatured  Boolean          @default(false)
  creatorId   Int
  creator     User             @relation(fields: [creatorId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  zines       CollectionZine[]
  featured    FeaturedCollection?
}

model CollectionZine {
  id           Int       @id @default(autoincrement())
  collectionId Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  zineId       Int
  zine         Zine      @relation(fields: [zineId], references: [id], onDelete: Cascade)
  sortOrder    Int       @default(0)
  recommendNote String?
  addedAt      DateTime  @default(now())

  @@unique([collectionId, zineId])
}

model FeaturedCollection {
  id             Int      @id @default(autoincrement())
  collectionId   Int      @unique
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  bannerImage    String?
  bannerTitle    String?
  bannerSubtitle String?
  sortOrder      Int      @default(0)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Crowdfunding {
  id              Int                 @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  category        String              @default("ZINE")
  tags            String              @default("[]")
  targetAmount    Float               @default(0)
  currentAmount   Float               @default(0)
  backerCount     Int                 @default(0)
  deadline        DateTime?
  startTime       DateTime?
  status          String              @default("DRAFT")
  rejectionReason String?
  reviewerId      Int?
  reviewer        User?               @relation("CrowdfundingReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  isFeatured      Boolean             @default(false)
  sortOrder       Int                 @default(0)
  viewCount       Int                 @default(0)
  stockThreshold  Int                 @default(0)
  lowStockAlert   Boolean             @default(false)
  creatorId       Int
  creator         User                @relation(fields: [creatorId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tiers           CrowdfundingTier[]
  orders          CrowdfundingOrder[]
}

