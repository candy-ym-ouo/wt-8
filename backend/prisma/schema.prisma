generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zines       Zine[]
  submissions Submission[]
  messages    Message[]    @relation("UserMessages")
  messagesReceived Message[] @relation("MessageReceiver")
  subscriptions Subscription[]
  createdTopics Topic[]
  topicSubmissions TopicSubmission[]
  reviewedTopicSubmissions TopicSubmission[] @relation("TopicSubmissionReviewer")
  createdSchedules TopicSchedule[]
  growth      UserGrowth?
  benefits    UserBenefit[]
  createdEvents Event[]
  eventRegistrations EventRegistration[]
  reviewedEventRegistrations EventRegistration[] @relation("EventRegistrationReviewer")
  eventCheckIns EventCheckIn[]
  operatedEventCheckIns EventCheckIn[] @relation("EventCheckInOperator")
  createdCollections Collection[]
  createdCollaborations Collaboration[]
  reviewedCollaborations Collaboration[] @relation("CollaborationReviewer")
  collaborationApplications CollaborationApplication[]
  reviewedCollaborationApplications CollaborationApplication[] @relation("CollaborationApplicationReviewer")
  createdCrowdfundings Crowdfunding[]
  reviewedCrowdfundings Crowdfunding[] @relation("CrowdfundingReviewer")
  crowdfundingOrders CrowdfundingOrder[]
  reports Report[] @relation("UserReports")
  reportedBy Report[] @relation("ReportReporter")
  targetReports Report[] @relation("ReportTarget")
  appeals Appeal[] @relation("AppealAppellant")
  handledAppeals Appeal[] @relation("AppealHandler")
  reportLogs ReportLog[]
  calendarEvents CreationCalendar[]
  calendarReminders CalendarReminder[]
  calendarSubscriptions CalendarSubscription[]
  proofreadingAssigned ProofreadingTask[] @relation("ProofreadingAssignee")
  proofreadingCreated ProofreadingTask[] @relation("ProofreadingCreator")
  editorTemplates EditorTemplate[]
  collaborationNotes CollaborationNote[]
  workflowRecords WorkflowRecord[]
  reviewPerformance ReviewPerformance?
}

model Collaboration {
  id              Int                         @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  category        String                      @default("OTHER")
  tags            String                      @default("[]")
  requirements    String?
  deliverables    String?
  compensation    String?
  deadline        DateTime?
  status          String                      @default("DRAFT")
  rejectionReason String?
  reviewerId      Int?
  reviewer        User?                       @relation("CollaborationReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  isFeatured      Boolean                     @default(false)
  sortOrder       Int                         @default(0)
  viewCount       Int                         @default(0)
  creatorId       Int
  creator         User                        @relation(fields: [creatorId], references: [id])
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  applications    CollaborationApplication[]
}

model CollaborationApplication {
  id              Int           @id @default(autoincrement())
  collaborationId Int
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  portfolio       String?
  skills          String?
  motivation      String?
  contactInfo     String?
  status          String        @default("PENDING")
  rejectionReason String?
  reviewerId      Int?
  reviewer        User?         @relation("CollaborationApplicationReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([collaborationId, userId])
}

model Zine {
  id          Int         @id @default(autoincrement())
  title       String
  description String
  coverImage  String
  content     String
  authorId    Int
  author      User        @relation(fields: [authorId], references: [id])
  category    String
  tags        String
  status      String      @default("PUBLISHED")
  views       Int         @default(0)
  likes       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subscriptions Subscription[]
  reviews       Review[]
  collections   CollectionZine[]
  proofreadingTasks ProofreadingTask[]
}

model Submission {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  content     String
  images      String
  status      String   @default("PENDING")
  rejectionReason String?
  reviewerId  Int?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  review Review?
  proofreadingTasks ProofreadingTask[]
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  zineId    Int
  zine      Zine     @relation(fields: [zineId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, zineId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("UserMessages", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  title      String
  content    String
  isRead     Boolean  @default(false)
  type       String   @default("SYSTEM")
  createdAt  DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  submissionId Int  @unique
  submission   Submission @relation(fields: [submissionId], references: [id])
  zineId    Int?
  zine      Zine?    @relation(fields: [zineId], references: [id])
  status    String
  feedback  String?
  createdAt DateTime @default(now())
}

model Topic {
  id              Int               @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  content         String
  category        String
  tags            String            @default("[]")
  deadline        DateTime?
  startDate       DateTime?
  endDate         DateTime?
  status          String            @default("DRAFT")
  isFeatured      Boolean           @default(false)
  sortOrder       Int               @default(0)
  maxSubmissions  Int               @default(0)
  requirements    String?
  prizes          String?
  creatorId       Int
  creator         User              @relation(fields: [creatorId], references: [id])
  reviewers       String            @default("[]")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  submissions     TopicSubmission[]
  schedules       TopicSchedule[]
  featured        FeaturedTopic?
}

model TopicSubmission {
  id          Int      @id @default(autoincrement())
  topicId     Int
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  content     String
  images      String   @default("[]")
  status      String   @default("PENDING")
  rejectionReason String?
  reviewerId  Int?
  reviewer    User?    @relation("TopicSubmissionReviewer", fields: [reviewerId], references: [id])
  reviewedAt  DateTime?
  scheduleId  Int?
  schedule    TopicSchedule? @relation(fields: [scheduleId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TopicSchedule {
  id            Int               @id @default(autoincrement())
  topicId       Int
  topic         Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  publishDate   DateTime
  status        String            @default("PENDING")
  creatorId     Int
  creator       User              @relation(fields: [creatorId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  submissions   TopicSubmission[]
}

model FeaturedTopic {
  id         Int      @id @default(autoincrement())
  topicId    Int      @unique
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  bannerImage String?
  bannerTitle String?
  bannerSubtitle String?
  sortOrder  Int      @default(0)
  startDate  DateTime?
  endDate    DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Level {
  id          Int          @id @default(autoincrement())
  name        String
  level       Int          @unique
  minExp      Int          @unique
  icon        String?
  description String?
  benefits    String       @default("[]")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userGrowths UserGrowth[]
}

model Badge {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  code          String         @unique
  icon          String
  description   String
  category      String         @default("GENERAL")
  rarity        String         @default("COMMON")
  expReward     Int            @default(0)
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  userBadges    UserBadge[]
  achievements  Achievement[]
}

model Achievement {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  description String
  category    String   @default("CREATION")
  condition   String
  targetValue Int      @default(1)
  expReward   Int      @default(0)
  badgeId     Int?
  badge       Badge?   @relation(fields: [badgeId], references: [id])
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userAchievements UserAchievement[]
}

model Task {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String
  category    String   @default("DAILY")
  type        String   @default("SUBMISSION")
  condition   String
  targetValue Int      @default(1)
  expReward   Int      @default(10)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userTasks   UserTask[]
}

model Benefit {
  id          Int           @id @default(autoincrement())
  name        String
  code        String        @unique
  description String
  type        String        @default("PRIVILEGE")
  value       String?
  minLevel    Int           @default(1)
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userBenefits UserBenefit[]
}

model UserGrowth {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  totalExp    Int      @default(0)
  currentExp  Int      @default(0)
  levelId     Int?
  level       Level?   @relation(fields: [levelId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBadges      UserBadge[]
  userAchievements UserAchievement[]
  userTasks       UserTask[]
  growthLogs      GrowthLog[]
}

model UserBadge {
  id          Int      @id @default(autoincrement())
  userGrowthId Int
  userGrowth  UserGrowth @relation(fields: [userGrowthId], references: [id])
  badgeId     Int
  badge       Badge    @relation(fields: [badgeId], references: [id])
  unlockedAt  DateTime @default(now())
  source      String?

  @@unique([userGrowthId, badgeId])
}

model UserAchievement {
  id          Int      @id @default(autoincrement())
  userGrowthId Int
  userGrowth  UserGrowth @relation(fields: [userGrowthId], references: [id])
  achievementId Int
  achievement Achievement @relation(fields: [achievementId], references: [id])
  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userGrowthId, achievementId])
}

model UserTask {
  id          Int      @id @default(autoincrement())
  userGrowthId Int
  userGrowth  UserGrowth @relation(fields: [userGrowthId], references: [id])
  taskId      Int
  task        Task     @relation(fields: [taskId], references: [id])
  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  date        String
  week        String?
  month       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userGrowthId, taskId, date])
}

model GrowthLog {
  id          Int      @id @default(autoincrement())
  userGrowthId Int
  userGrowth  UserGrowth @relation(fields: [userGrowthId], references: [id])
  type        String
  amount      Int      @default(0)
  description String
  sourceType  String?
  sourceId    Int?
  createdAt   DateTime @default(now())
}

model UserBenefit {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  benefitId   Int
  benefit     Benefit  @relation(fields: [benefitId], references: [id])
  isActive    Boolean  @default(true)
  activatedAt DateTime @default(now())
  expiresAt   DateTime?

  @@unique([userId, benefitId])
}

model Event {
  id              Int                @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  location        String
  address         String?
  category        String             @default("OTHER")
  tags            String             @default("[]")
  startTime       DateTime
  endTime         DateTime
  registrationDeadline DateTime?
  maxParticipants Int                @default(0)
  minParticipants Int                @default(0)
  fee             Float              @default(0)
  organizer       String?
  organizerContact String?
  requirements    String?
  notice          String?
  status          String             @default("DRAFT")
  isFeatured      Boolean            @default(false)
  sortOrder       Int                @default(0)
  viewCount       Int                @default(0)
  creatorId       Int
  creator         User               @relation(fields: [creatorId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  registrations   EventRegistration[]
  checkIns        EventCheckIn[]
}

model EventRegistration {
  id          Int      @id @default(autoincrement())
  eventId     Int
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  name        String
  phone       String
  email       String?
  company     String?
  note        String?
  status      String   @default("PENDING")
  rejectionReason String?
  reviewerId  Int?
  reviewer    User?    @relation("EventRegistrationReviewer", fields: [reviewerId], references: [id])
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checkIn     EventCheckIn?

  @@unique([eventId, userId])
}

model EventCheckIn {
  id              Int      @id @default(autoincrement())
  eventId         Int
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationId  Int      @unique
  registration    EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  checkInTime     DateTime @default(now())
  checkInType     String   @default("QRCODE")
  operatorId      Int?
  operator        User?    @relation("EventCheckInOperator", fields: [operatorId], references: [id])
  remark          String?
  createdAt       DateTime @default(now())

  @@unique([eventId, registrationId])
}

model Collection {
  id          Int              @id @default(autoincrement())
  title       String
  description String
  coverImage  String?
  content     String
  category    String
  tags        String           @default("[]")
  status      String           @default("DRAFT")
  sortOrder   Int              @default(0)
  viewCount   Int              @default(0)
  likeCount   Int              @default(0)
  isFeatured  Boolean          @default(false)
  creatorId   Int
  creator     User             @relation(fields: [creatorId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  zines       CollectionZine[]
  featured    FeaturedCollection?
}

model CollectionZine {
  id           Int       @id @default(autoincrement())
  collectionId Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  zineId       Int
  zine         Zine      @relation(fields: [zineId], references: [id], onDelete: Cascade)
  sortOrder    Int       @default(0)
  recommendNote String?
  addedAt      DateTime  @default(now())

  @@unique([collectionId, zineId])
}

model FeaturedCollection {
  id             Int      @id @default(autoincrement())
  collectionId   Int      @unique
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  bannerImage    String?
  bannerTitle    String?
  bannerSubtitle String?
  sortOrder      Int      @default(0)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Crowdfunding {
  id              Int                 @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  category        String              @default("ZINE")
  tags            String              @default("[]")
  targetAmount    Float               @default(0)
  currentAmount   Float               @default(0)
  backerCount     Int                 @default(0)
  deadline        DateTime?
  startTime       DateTime?
  status          String              @default("DRAFT")
  rejectionReason String?
  reviewerId      Int?
  reviewer        User?               @relation("CrowdfundingReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  isFeatured      Boolean             @default(false)
  sortOrder       Int                 @default(0)
  viewCount       Int                 @default(0)
  stockThreshold  Int                 @default(0)
  lowStockAlert   Boolean             @default(false)
  creatorId       Int
  creator         User                @relation(fields: [creatorId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tiers           CrowdfundingTier[]
  orders          CrowdfundingOrder[]
}

model CrowdfundingTier {
  id              Int                 @id @default(autoincrement())
  crowdfundingId  Int
  crowdfunding    Crowdfunding        @relation(fields: [crowdfundingId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  price           Float
  stock           Int                 @default(0)
  soldCount       Int                 @default(0)
  sortOrder       Int                 @default(0)
  deliveryDate    DateTime?
  perks           String              @default("[]")
  isUnlimited     Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  orders          CrowdfundingOrder[]

  @@index([crowdfundingId])
}

model CrowdfundingOrder {
  id              Int                 @id @default(autoincrement())
  orderNo         String              @unique
  crowdfundingId  Int
  crowdfunding    Crowdfunding        @relation(fields: [crowdfundingId], references: [id])
  tierId          Int
  tier            CrowdfundingTier    @relation(fields: [tierId], references: [id])
  userId          Int
  user            User                @relation(fields: [userId], references: [id])
  amount          Float
  quantity        Int                 @default(1)
  status          String              @default("PENDING")
  receiverName    String?
  receiverPhone   String?
  receiverAddress String?
  remark          String?
  paymentMethod   String              @default("BALANCE")
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  trackingNumber  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([crowdfundingId])
  @@index([userId])
  @@index([status])
}

model Report {
  id              Int       @id @default(autoincrement())
  type            String    @default("CONTENT")
  reason          String
  description     String?
  targetType      String
  targetId        Int
  targetTitle     String?
  evidence        String    @default("[]")
  status          String    @default("PENDING")
  priority        String    @default("NORMAL")
  handlerLevel    String    @default("LEVEL_1")
  handlerId       Int?
  handler         User?     @relation("UserReports", fields: [handlerId], references: [id])
  handledAt       DateTime?
  handleResult    String?
  handleNote      String?
  penaltyType     String?
  penaltyDetail   String?
  reporterId      Int
  reporter        User      @relation("ReportReporter", fields: [reporterId], references: [id])
  targetUserId    Int?
  targetUser      User?     @relation("ReportTarget", fields: [targetUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  appeals         Appeal[]
  logs            ReportLog[]

  @@index([status])
  @@index([reporterId])
  @@index([handlerId])
  @@index([priority])
  @@index([createdAt])
}

model Appeal {
  id              Int      @id @default(autoincrement())
  reportId        Int
  report          Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reason          String
  evidence        String   @default("[]")
  status          String   @default("PENDING")
  handlerId       Int?
  handler         User?    @relation("AppealHandler", fields: [handlerId], references: [id])
  handledAt       DateTime?
  handleResult    String?
  handleNote      String?
  appellantId     Int
  appellant       User     @relation("AppealAppellant", fields: [appellantId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  logs            ReportLog[]

  @@index([reportId])
  @@index([status])
  @@index([appellantId])
}

model ReportLog {
  id          Int      @id @default(autoincrement())
  reportId    Int
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  appealId    Int?
  appeal      Appeal?  @relation(fields: [appealId], references: [id], onDelete: Cascade)
  action      String
  detail      String?
  operatorId  Int
  operator    User     @relation(fields: [operatorId], references: [id])
  createdAt   DateTime @default(now())

  @@index([reportId])
  @@index([appealId])
  @@index([createdAt])
}

model CreationCalendar {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  eventType       String   @default("SCHEDULE")
  startDate       DateTime
  endDate         DateTime?
  color           String   @default("#d4624a")
  status          String   @default("ACTIVE")
  isAllDay        Boolean  @default(true)
  reminderEnabled Boolean  @default(false)
  reminderMinutes Int      @default(30)
  linkType        String?
  linkId          Int?
  creatorId       Int
  creator         User     @relation(fields: [creatorId], references: [id])
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reminders       CalendarReminder[]
  subscriptions   CalendarSubscription[]

  @@index([creatorId])
  @@index([startDate])
  @@index([eventType])
  @@index([status])
}

model CalendarReminder {
  id              Int              @id @default(autoincrement())
  calendarEventId Int
  calendarEvent   CreationCalendar @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  remindAt        DateTime
  isSent          Boolean          @default(false)
  createdAt       DateTime         @default(now())

  @@unique([calendarEventId, userId])
  @@index([userId])
  @@index([remindAt])
  @@index([isSent])
}

model CalendarSubscription {
  id              Int              @id @default(autoincrement())
  calendarEventId Int
  calendarEvent   CreationCalendar @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  createdAt       DateTime         @default(now())

  @@unique([calendarEventId, userId])
  @@index([userId])
}

model ProofreadingTask {
  id           Int       @id @default(autoincrement())
  zineId       Int?
  zine         Zine?     @relation(fields: [zineId], references: [id])
  submissionId Int?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  title        String
  content      String
  type         String    @default("ZINE")
  status       String    @default("PENDING")
  priority     String    @default("NORMAL")
  deadline     DateTime?
  assigneeId   Int?
  assignee     User?     @relation("ProofreadingAssignee", fields: [assigneeId], references: [id])
  creatorId    Int
  creator      User      @relation("ProofreadingCreator", fields: [creatorId], references: [id])
  feedback     String?
  corrections  String    @default("[]")
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([priority])
}

model EditorTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  type        String   @default("SUBMISSION")
  category    String   @default("GENERAL")
  content     String
  description String?
  isPublic    Boolean  @default(true)
  sortOrder   Int      @default(0)
  usageCount  Int      @default(0)
  creatorId   Int
  creator     User     @relation(fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([category])
}

model CollaborationNote {
  id           Int       @id @default(autoincrement())
  targetType   String
  targetId     Int
  targetTitle  String?
  content      String
  color        String    @default("#ffeaa7")
  isPinned     Boolean   @default(false)
  creatorId    Int
  creator      User      @relation(fields: [creatorId], references: [id])
  mentions     String    @default("[]")
  attachments  String    @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([targetType, targetId])
  @@index([creatorId])
  @@index([isPinned])
}

model WorkflowRecord {
  id           Int      @id @default(autoincrement())
  targetType   String
  targetId     Int
  targetTitle  String?
  action       String
  fromStatus   String?
  toStatus     String?
  remark       String?
  metadata     String   @default("{}")
  operatorId   Int
  operator     User     @relation(fields: [operatorId], references: [id])
  createdAt    DateTime @default(now())

  @@index([targetType, targetId])
  @@index([operatorId])
  @@index([action])
  @@index([createdAt])
}

model ReviewPerformance {
  id            Int      @id @default(autoincrement())
  reviewerId    Int      @unique
  reviewer      User     @relation(fields: [reviewerId], references: [id])
  periodType    String   @default("MONTHLY")
  periodStart   DateTime
  periodEnd     DateTime
  totalReviews  Int      @default(0)
  approvedCount Int      @default(0)
  rejectedCount Int      @default(0)
  avgReviewTime Float    @default(0)
  avgScore      Float    @default(0)
  submissions   Int      @default(0)
  topicSubs     Int      @default(0)
  collaborations Int     @default(0)
  crowdfundings Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([periodType])
  @@index([reviewerId])
}
