generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zines       Zine[]
  submissions Submission[]
  messages    Message[]    @relation("UserMessages")
  messagesReceived Message[] @relation("MessageReceiver")
  subscriptions Subscription[]
  createdTopics Topic[]
  topicSubmissions TopicSubmission[]
  reviewedTopicSubmissions TopicSubmission[] @relation("TopicSubmissionReviewer")
  createdSchedules TopicSchedule[]
}

model Zine {
  id          Int         @id @default(autoincrement())
  title       String
  description String
  coverImage  String
  content     String
  authorId    Int
  author      User        @relation(fields: [authorId], references: [id])
  category    String
  tags        String
  status      String      @default("PUBLISHED")
  views       Int         @default(0)
  likes       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subscriptions Subscription[]
  reviews       Review[]
}

model Submission {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  content     String
  images      String
  status      String   @default("PENDING")
  rejectionReason String?
  reviewerId  Int?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  review Review?
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  zineId    Int
  zine      Zine     @relation(fields: [zineId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, zineId])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("UserMessages", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  title      String
  content    String
  isRead     Boolean  @default(false)
  type       String   @default("SYSTEM")
  createdAt  DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  submissionId Int  @unique
  submission   Submission @relation(fields: [submissionId], references: [id])
  zineId    Int?
  zine      Zine?    @relation(fields: [zineId], references: [id])
  status    String
  feedback  String?
  createdAt DateTime @default(now())
}

model Topic {
  id              Int               @id @default(autoincrement())
  title           String
  description     String
  coverImage      String?
  content         String
  category        String
  tags            String            @default("[]")
  deadline        DateTime?
  startDate       DateTime?
  endDate         DateTime?
  status          String            @default("DRAFT")
  isFeatured      Boolean           @default(false)
  sortOrder       Int               @default(0)
  maxSubmissions  Int               @default(0)
  requirements    String?
  prizes          String?
  creatorId       Int
  creator         User              @relation(fields: [creatorId], references: [id])
  reviewers       String            @default("[]")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  submissions     TopicSubmission[]
  schedules       TopicSchedule[]
  featured        FeaturedTopic?
}

model TopicSubmission {
  id          Int      @id @default(autoincrement())
  topicId     Int
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  content     String
  images      String   @default("[]")
  status      String   @default("PENDING")
  rejectionReason String?
  reviewerId  Int?
  reviewer    User?    @relation("TopicSubmissionReviewer", fields: [reviewerId], references: [id])
  reviewedAt  DateTime?
  scheduleId  Int?
  schedule    TopicSchedule? @relation(fields: [scheduleId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TopicSchedule {
  id            Int               @id @default(autoincrement())
  topicId       Int
  topic         Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  publishDate   DateTime
  status        String            @default("PENDING")
  creatorId     Int
  creator       User              @relation(fields: [creatorId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  submissions   TopicSubmission[]
}

model FeaturedTopic {
  id         Int      @id @default(autoincrement())
  topicId    Int      @unique
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  bannerImage String?
  bannerTitle String?
  bannerSubtitle String?
  sortOrder  Int      @default(0)
  startDate  DateTime?
  endDate    DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
